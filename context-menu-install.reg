Windows Registry Editor Version 5.00

; =============================================
; CLI Chat - 우클릭 컨텍스트 메뉴 등록
; 폴더에서 우클릭 → "여기서 CLI Chat 열기"
;
; 사용법: 이 파일을 더블클릭하여 레지스트리에 등록
; 제거: context-menu-uninstall.reg 실행
;
; 주의: 설치 경로를 실제 경로로 수정하세요!
; 기본값: %LOCALAPPDATA%\Programs\cli-chat-app\CLI Chat.exe
; =============================================

; 폴더 배경에서 우클릭
[HKEY_CURRENT_USER\Software\Classes\Directory\Background\shell\CLIChat]
@="여기서 CLI Chat 열기"
"Icon"="\"%LOCALAPPDATA%\\Programs\\cli-chat-app\\CLI Chat.exe\""

[HKEY_CURRENT_USER\Software\Classes\Directory\Background\shell\CLIChat\command]
@="\"%LOCALAPPDATA%\\Programs\\cli-chat-app\\CLI Chat.exe\" --cwd \"%V\""

; 폴더를 직접 우클릭
[HKEY_CURRENT_USER\Software\Classes\Directory\shell\CLIChat]
@="CLI Chat으로 열기"
"Icon"="\"%LOCALAPPDATA%\\Programs\\cli-chat-app\\CLI Chat.exe\""

[HKEY_CURRENT_USER\Software\Classes\Directory\shell\CLIChat\command]
@="\"%LOCALAPPDATA%\\Programs\\cli-chat-app\\CLI Chat.exe\" --cwd \"%1\""
