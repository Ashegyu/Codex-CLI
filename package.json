{
  "name": "cli-chat-app",
  "version": "1.0.0",
  "description": "Conversational AI Chat App - Beautiful markdown rendering for Claude, Codex and more",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win",
    "build:portable": "electron-builder --win portable"
  },
  "keywords": ["chat", "cli", "electron", "claude", "codex", "ai"],
  "author": "JGKim",
  "license": "MIT",
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8"
  },
  "dependencies": {
    "marked": "^15.0.0",
    "highlight.js": "^11.11.0",
    "node-pty": "^1.0.0"
  },
  "build": {
    "appId": "com.jgkim.cli-chat",
    "productName": "CLI Chat",
    "npmRebuild": false,
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "renderer/**/*",
      "node_modules/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "CLI Chat"
    }
  }
}
